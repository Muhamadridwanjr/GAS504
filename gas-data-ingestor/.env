# ─────────────────────────────────────────────
#   gas-data-ingestor  Environment Variables
# ─────────────────────────────────────────────

PORT=9604
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Storage ───────────────────────────────────
STORAGE_TYPE=minio
S3_ENDPOINT=http://gas-minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gas-data
S3_REGION=us-east-1

# ── Source ────────────────────────────────────
SOURCE_TYPE=csv
SOURCE_PATH=/data/gold.csv
SOURCE_API_URL=
SOURCE_API_KEY=

# ── Processing ────────────────────────────────
CHUNK_SIZE=100000
PARTITION_BY=["year","month"]
DEFAULT_SYMBOL=XAUUSD

# ── Summary ───────────────────────────────────
GENERATE_SUMMARY=true
SUMMARY_PERIOD=month

# ── Vector DB ─────────────────────────────────
VECTOR_DB_URL=http://gas-vector-db:9004
VECTOR_DB_COLLECTION=market_summaries

# ── Embedding ─────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-...

# ── Scheduling ────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 2 * * *

# ── Internal Security ─────────────────────────
INTERNAL_API_KEY=gas-internal-secret-key
