# GAS Terminal Backend
APP_NAME=GAS Terminal Backend
DEBUG=true
PORT=8085
HOST=0.0.0.0

# Redis
REDIS_HOST=gas-redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=30

# Gateway API Key
GATEWAY_API_KEY=gas-internal-secret-key

# Upstream Service URLs
SIGNAL_SERVICE_URL=http://gas-signal-service:8106
CALENDAR_NEWS_URL=http://gas-calendar-news-service:9601
FUNDAMENTAL_DATA_URL=http://gas-fundamental-data-service:9603
CHART_SERVICE_URL=http://gas-chart-service:9700
USER_SERVICE_URL=http://gas-user-service:8002
TRADINGPLAN_URL=http://gas-tradingplan-service:9602
JOURNAL_URL=http://gas-journal-service:8107
MT5_DATA_URL=http://gas-mt5-data-service:8100
SMC_ENGINE_URL=http://gas-smc-engine:8000
INDICATOR_ENGINE_URL=http://gas-indicator-engine:8203
REALTIME_HUB_URL=http://gas-realtime-hub:8111
SCREENER_URL=http://gas-screener-service:9600

QUANT_ORCH_URL=http://gas-quant-orch:9500
TERM_SERVICE_URL=http://gas-term-service:8205

# CORS
CORS_ORIGINS=*
