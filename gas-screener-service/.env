# ─────────────────────────────────────────────
#   gas-screener-service  Environment Variables
# ─────────────────────────────────────────────
PORT=9600
ENVIRONMENT=development
LOG_LEVEL=INFO

INDICATOR_ENGINE_URL=http://gas-indicator-engine:8203
SMC_ENGINE_URL=http://gas-smc-engine:8006
FEATURE_ENGINE_URL=
DEFAULT_SYMBOLS=["XAUUSD","BTCUSD","EURUSD","GBPUSD","US30"]
CONCURRENCY_LIMIT=20
REQUEST_TIMEOUT=5.0
REDIS_URL=redis://localhost:6379
CACHE_TTL=60
INTERNAL_API_KEY=gas-internal-secret-key
