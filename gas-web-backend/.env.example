# FastAPI
APP_NAME=GAS Web Backend
DEBUG=false
PORT=8005

# Gateway (untuk akses service lain)
GATEWAY_URL=http://gateway:8000

# Service Internal (jika perlu akses langsung)
USER_SERVICE_URL=http://gas-user-service:8002
BILLING_SERVICE_URL=http://gas-billing-service:8004
JOURNAL_SERVICE_URL=http://gas-journal-service:8107
SIGNAL_SERVICE_URL=http://gas-signal-service:8106
TCG_SERVICE_URL=http://gas-tcg-service:8300
NOTIFICATION_SERVICE_URL=http://gas-notification-service:8112

# Menggunakan local redis untuk dev, db redis jika di compose
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
