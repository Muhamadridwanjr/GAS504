# ===== FastAPI =====
APP_NAME=GAS Gateway API
DEBUG=true
PORT=8000

# ===== Redis (untuk rate limit) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ===== Supabase JWT Secret (untuk verifikasi token) =====
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ===== Gateway API Key (untuk sistem-ke-sistem) =====
GATEWAY_API_KEY=rahasia-banget-123-ganti-ya

# ===== Production Guard =====
ENABLE_DOCS=true

# ===== Service URLs (VPS 1 - Core) =====
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
BILLING_SERVICE_URL=http://localhost:8004
TELEGRAM_BOT_URL=http://localhost:8003
WEB_BACKEND_URL=http://localhost:8005

# ===== Service URLs (VPS 2 - Engine) =====
ENGINE_ORCHESTRATOR_URL=http://localhost:8105
SIGNAL_SERVICE_URL=http://localhost:8106
JOURNAL_SERVICE_URL=http://localhost:8107

# ===== Service URLs (VPS 3 - AI) =====
RAG_TECHNICAL_URL=http://localhost:9001
RAG_MACRO_URL=http://localhost:9002
AI_ORCHESTRATOR_URL=http://localhost:9003

# ===== Service URLs (VPS 4 - Market Data) =====
MT5_DATA_SERVICE_URL=http://localhost:8100
TV_TECHNICAL_URL=http://localhost:8200
TV_FUNDAMENTAL_URL=http://localhost:8201
NOTIFICATION_SERVICE_URL=http://localhost:8112
TCG_SERVICE_URL=http://localhost:8300
NFT_SERVICE_URL=http://localhost:8301
MARKETPLACE_SERVICE_URL=http://localhost:8302

# ===== WebSocket URLs (untuk referensi) =====
