# ══════════════════════════════════════════════════════════════════
# GAS Terminal v3 — Environment Configuration
# ══════════════════════════════════════════════════════════════════

# ── GAS Platform Login ────────────────────────────────────────────
# Ini adalah akun kamu di website gasstrategyai.xyz
# Dipakai oleh command: gas login
# Setelah login, JWT token otomatis disimpan di GAS_TOKEN di bawah
GAS_EMAIL=admin@gasstrategyai.xyz
GAS_PASSWORD=
GAS_TOKEN=

# ── Core Service URLs ─────────────────────────────────────────────
# Sesuaikan dengan environment kamu:
# - Kalau docker-compose running: pakai nama container (gas-xxx:PORT)
# - Kalau local dev: pakai localhost:PORT
GATEWAY_URL=http://localhost:8000
WEB_BACKEND_URL=http://localhost:8005
TERMINAL_BACKEND_URL=http://localhost:8060
AUTH_URL=http://localhost:8001
AGENT_ENGINE_URL=http://localhost:9000

MT5_WEBSOCKET_URL=http://localhost:8001
BINANCE_SERVICE_URL=http://localhost:9612
SIGNAL_SERVICE_URL=http://localhost:8106
SMC_ENGINE_URL=http://localhost:8011
RISK_ENGINE_URL=http://localhost:8021
QUANT_BACKTESTER_URL=http://localhost:8030
SCREENER_SERVICE_URL=http://localhost:8025
CALENDAR_NEWS_URL=http://localhost:8019
OBSERVABILITY_URL=http://localhost:9090

# ══════════════════════════════════════════════════════════════════
# AI MODEL API KEYS
# ══════════════════════════════════════════════════════════════════

# ── DEFAULT PROVIDER ──────────────────────────────────────────────
# Pilih salah satu: claude | openrouter | kimi | gemini
# OpenRouter direkomendasikan karena ada banyak model di 1 key
DEFAULT_AI_PROVIDER=openrouter

# ── 1. OpenRouter ─────────────────────────────────────────────────
# 1 key untuk akses DeepSeek, Llama, Mistral, Claude, Gemini, dll
# Key sudah ada dari gas-strategy-core
OPENROUTER_API_KEY=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
# Model default (bisa ganti ke model lain kapan saja via TUI)
OPENROUTER_MODEL=deepseek/deepseek-chat
# Model lain yang bisa kamu pakai (tinggal ganti OPENROUTER_MODEL):
# deepseek/deepseek-r1
# deepseek/deepseek-r1:free
# anthropic/claude-sonnet-4-6
# google/gemini-2.0-flash-001
# meta-llama/llama-3.1-70b-instruct
# mistralai/mistral-large
# qwen/qwen-2.5-72b-instruct

# ── 2. Kimi AI / Moonshot ─────────────────────────────────────────
# Ditemukan dari gas-ai-orchestrator — sudah ada keynya
KIMI_API_KEY=sk-jHaST2FHxfBpQv6ulgWrIeI7D07m4jdgNiGlDpoob6ld3cV4
# Key alternatif (dari gas-web-backend):
# Support  : sk-oqNrlbAvX2K0027o31RaokOZtbAdX2oyIepS2ixCClrLyH10
# Analysis : sk-4wPbTf8cQzNx6yc1t5FjzFkiUUMLOJ9IAYwX8HJstpAjoVYN
KIMI_MODEL=moonshot-v1-32k
# Model options: moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k

# ── 3. Google Gemini AI Studio ────────────────────────────────────
# Isi dengan API key dari https://aistudio.google.com/
# (kalau belum punya, kosongkan — ada fallback ke provider lain)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── 4. Vertex AI (Google Cloud) ───────────────────────────────────
# Dari gas-ai-orchestrator (project ID sudah ada)
VERTEX_PROJECT_ID=gen-lang-client-0060492434
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash
# Path ke service account JSON (mount di container atau lokal)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json

# ── 5. Anthropic / Claude ─────────────────────────────────────────
# Isi jika punya key Anthropic langsung (bukan via OpenRouter)
# Kalau pakai Claude via OpenRouter, tidak perlu ini
ANTHROPIC_API_KEY=
MODEL_COMPLEX=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001

# ══════════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379/0

# ── Telegram Alert ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Terminal Info ─────────────────────────────────────────────────
WEBSITE_URL=gasstrategyai.xyz
SERVER_NAME=VPS Trading Node
DOMAINS_BASE=/root/gasstrategyai/domains
AGENT_ENGINE_DIR=/root/gasstrategyai/agent-engine
