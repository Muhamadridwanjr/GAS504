# ─────────────────────────────────────────────
#   gas-rag-technical  Environment Variables
# ─────────────────────────────────────────────

PORT=9001
ENVIRONMENT=development
LOG_LEVEL=INFO

# Provider
DEFAULT_PROVIDER=openai
ENABLE_PROVIDER_ROUTING=true

# ── Vertex AI ────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_AGENT_ID=
VERTEX_MODEL=gemini-1.5-pro
VERTEX_EMBEDDING_MODEL=text-embedding-004

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Database ───────────────────────────
VECTOR_DB_TYPE=chroma
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_API_KEY=
VECTOR_DB_COLLECTION=technical_analysis

# ── Market Data Service ───────────────────────
MARKET_DATA_SERVICE_URL=http://gas-market-data-processor:8100
MARKET_DATA_API_KEY=

# ── Knowledge Base ────────────────────────────
KNOWLEDGE_BASE_PATH=./data/knowledge_base
INDEXING_INTERVAL=3600
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# ── Redis Cache ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ── Internal Security ─────────────────────────
INTERNAL_API_KEY=gas-internal-secret-key
