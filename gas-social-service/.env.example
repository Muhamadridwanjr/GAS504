# App Config
PORT=8500
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@gas-user-db:5432/gas_social

# Redis
REDIS_URL=redis://gas-redis:6379/3

# Internal API Key (for communication between services)
INTERNAL_API_KEY=your_internal_api_key_here

# External Services
SIGNAL_SERVICE_URL=http://gas-signal-service:8106
SIGNAL_SERVICE_API_KEY=your_signal_service_api_key_here

NOTIFICATION_SERVICE_URL=http://gas-notification-service:8112
NOTIFICATION_SERVICE_API_KEY=your_notification_service_api_key_here

GATEWAY_URL=http://gas-gateway-api:8000
