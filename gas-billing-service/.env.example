# ===== FastAPI =====
APP_NAME=GAS Billing Service
DEBUG=true
PORT=8004

# ===== Database (Supabase/Postgres) =====
# Jika pakai Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Jika pakai PostgreSQL langsung
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gas_billing_db

# ===== Service URLs =====
USER_SERVICE_URL=http://gas-user-service:8002
AUTH_SERVICE_URL=http://gas-auth-service:8001

# ===== Redis (opsional) =====
REDIS_URL=redis://localhost:6379/0

# ===== Logging =====
LOG_LEVEL=INFO
