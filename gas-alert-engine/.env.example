# App config
PORT=8400
ENVIRONMENT=development
LOG_LEVEL=INFO
JWT_SECRET_KEY=your_jwt_secret_key_here

# Databases
DATABASE_URL=postgresql+asyncpg://postgres:postgres@gas-user-db:5432/gas_alerts
REDIS_URL=redis://gas-redis:6379/0

# Redis Channels & Queues
MARKET_DATA_CHANNEL=market:data
NOTIFICATION_QUEUE=notifications
ALERT_CACHE_PREFIX=alert

# Worker
WORKER_CONCURRENCY=10

# Services
NOTIFICATION_SERVICE_URL=http://gas-notification-service:8112
GATEWAY_URL=http://gas-gateway-api:8000
