# GAS Agent Engine — Environment Variables Example
# Copy this file to .env and fill in your values.

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gas:gaspassword@localhost:5432/gasstrategy
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── AI Model Configuration ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model tiers — do not change unless you know what you are doing
MODEL_COMPLEX=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_LOCAL=llama3.1:8b

# Local Ollama endpoint (optional, only needed if ENABLE_LOCAL_MODEL=true)
OLLAMA_BASE_URL=http://localhost:11434

# Token budgets
MODEL_COMPLEX_MAX_TOKENS=4096
MODEL_FAST_MAX_TOKENS=2048
CONTEXT_TOKEN_BUDGET=8000

# ─── Market Domain Services ───────────────────────────────────────────────────
MT5_WEBSOCKET_URL=http://gas-mt5-websocket:8001
MT5_DATA_SERVICE_URL=http://gas-mt5-data-service:8002
MARKET_DATA_PROCESSOR_URL=http://gas-market-data-processor:8003
REALTIME_HUB_URL=http://gas-realtime-hub:8004
DATA_INGESTOR_URL=http://gas-data-ingestor:8005
BINANCE_SERVICE_URL=http://gas-binance-service:9612

# ─── Analysis Domain Services ─────────────────────────────────────────────────
INDICATOR_ENGINE_URL=http://gas-indicator-engine:8010
SMC_ENGINE_URL=http://gas-smc-engine:8011
TREND_ENGINE_URL=http://gas-trend-engine:8012
PATTERN_DETECTOR_URL=http://gas-pattern-detector:8013
CORRELATION_URL=http://gas-correlation:8014
MARKET_PHASE_URL=http://gas-market-phase:8015
REGIME_DETECTOR_URL=http://gas-regime-detector:8016
ORDERFLOW_URL=http://gas-orderflow:8017
FUNDAMENTAL_DATA_URL=http://gas-fundamental-data-service:8018
CALENDAR_NEWS_URL=http://gas-calendar-news-service:8019
CHART_SERVICE_URL=http://gas-chart-service:8020

# ─── Trading Domain Services ──────────────────────────────────────────────────
SIGNAL_SERVICE_URL=http://gas-signal-service:8106
RISK_ENGINE_URL=http://gas-risk-engine:8021
ALERT_ENGINE_URL=http://gas-alert-engine:8022
TRADINGPLAN_URL=http://gas-tradingplan-service:8023
STATARB_ENGINE_URL=http://gas-statarb-engine:8024
SCREENER_SERVICE_URL=http://gas-screener-service:8025
FEATURE_ENGINE_URL=http://gas-feature-engine:8026

# ─── Quant Domain Services ────────────────────────────────────────────────────
QUANT_BACKTESTER_URL=http://gas-quant-backtester:8030
QUANT_ORCH_URL=http://gas-quant-orch:8031
STRATEGY_CORE_URL=http://gas-strategy-core:8010
ENGINE_ORCHESTRATOR_URL=http://gas-engine-orchestrator:8032

# ─── AI Domain Services ───────────────────────────────────────────────────────
RAG_MACRO_URL=http://gas-rag-macro:8040
RAG_TECHNICAL_URL=http://gas-rag-technical:8041
VECTOR_DB_URL=http://gas-vector-db:8042
AI_ORCHESTRATOR_URL=http://gas-ai-orchestrator:8050

# ─── Platform Domain Services ─────────────────────────────────────────────────
GATEWAY_API_URL=http://gas-gateway-api:8000
WEB_BACKEND_URL=http://gas-web-backend:8005
TERMINAL_BACKEND_URL=http://gas-terminal-backend:8060
AUTH_SERVICE_URL=http://gas-auth-service:8070
BILLING_SERVICE_URL=http://gas-billing-service:8080
USER_SERVICE_URL=http://gas-user-service:8071
NOTIFICATION_SERVICE_URL=http://gas-notification-service:8090
TELEGRAM_BOT_URL=http://gas-telegram-bot:8091
OBSERVABILITY_URL=http://gas-observability:9090

# ─── Agent Engine Settings ────────────────────────────────────────────────────
DOMAINS_BASE_PATH=/root/gasstrategyai/domains
AGENT_DEFAULT_TIMEOUT=30.0
AGENT_MAX_RETRIES=3
AGENT_RETRY_BASE_DELAY=1.0

# ─── Event Bus ────────────────────────────────────────────────────────────────
EVENT_BUS_STREAM_PREFIX=gas:events
EVENT_BUS_CONSUMER_GROUP=agent-engine
EVENT_BUS_MAX_STREAM_LEN=10000
EVENT_BUS_BLOCK_MS=1000

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALERT_CHAT_ID=-100123456789
TELEGRAM_SECURITY_CHAT_ID=-100987654321

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_LOCAL_MODEL=false
ENABLE_RESPONSE_CACHE=true
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300
